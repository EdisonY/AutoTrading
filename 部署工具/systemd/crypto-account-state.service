[Unit]
Description=Crypto Central Account State Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/crypto-auto-trader
EnvironmentFile=/etc/crypto-auto-trader/trading.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/crypto-auto-trader/.venv/bin/python -u /opt/crypto-auto-trader/account_state_service.py --interval 900 --write-legacy-snapshot --write-db
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
