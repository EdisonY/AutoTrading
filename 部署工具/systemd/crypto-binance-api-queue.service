[Unit]
Description=AutoTrading central Binance API queue (construction foundation)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/crypto-auto-trader
EnvironmentFile=-/etc/crypto-auto-trader/trading.env
ExecStartPre=/opt/crypto-auto-trader/.venv/bin/python /opt/crypto-auto-trader/binance_start_guard.py --scope any
ExecStart=/opt/crypto-auto-trader/.venv/bin/python -u /opt/crypto-auto-trader/binance_api_queue_service.py --interval 60 --execute
Restart=on-failure
RestartPreventExitStatus=75
RestartSec=10

[Install]
WantedBy=multi-user.target
