[Unit]
Description=AutoTrading Binance user-data-stream service (construction foundation)
After=network-online.target crypto-binance-api-queue.service
Wants=network-online.target crypto-binance-api-queue.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/crypto-auto-trader
EnvironmentFile=-/etc/crypto-auto-trader/trading.env
ExecStart=/opt/crypto-auto-trader/.venv/bin/python -u /opt/crypto-auto-trader/binance_user_stream_service.py --strategy A/v11 --apply-state
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
